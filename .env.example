# Example .env file for Money Manager Application
# Copy this file to .env and fill in your actual credentials

SPRING_APPLICATION_NAME=moneymanager
SPRING_PROFILES_ACTIVE=dev
SERVER_SERVLET_CONTEXT_PATH=/api/v1.0

# Cloud database configuration (Supabase)
POSTGRES_SUPABASE_URL=jdbc:postgresql://[YOUR_HOST]:[YOUR_PORT]/postgres?sslmode=require
POSTGRES_SUPABASE_USERNAME=[YOUR_SUPABASE_USERNAME]
POSTGRES_SUPABASE_PASSWORD=[YOUR_DATABASE_PASSWORD]
SUPABASE_DATASOURCE_DRIVER=org.postgresql.Driver

# Local MySQL fallback configuration
LOCAL_MYSQL_DATASOURCE_URL=jdbc:mysql://localhost:3306/[YOUR_DB_NAME]?createDatabaseIfNotExist=true
LOCAL_MYSQL_DATASOURCE_USERNAME=[YOUR_DB_USERNAME]
LOCAL_MYSQL_DATASOURCE_PASSWORD=[YOUR_DB_PASSWORD]
LOCAL_MYSQL_DATASOURCE_DRIVER=com.mysql.cj.jdbc.Driver

# Email configuration (Brevo)
SPRING_MAIL_HOST=smtp-relay.brevo.com
SPRING_MAIL_PORT=587
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS_ENABLE=true
SPRING_MAIL_PROTOCOL=smtp
BREVO_USERNAME=[YOUR_BREVO_LOGIN_EMAIL]
BREVO_PASSWORD=[YOUR_BREVO_SMTP_KEY]
BREVO_FROM_EMAIL=[YOUR_SENDER_EMAIL]

# Application URLs
MONEY_MANAGER_FRONTEND_URL=http://localhost:5173
MONEY_MANAGER_BACKEND_URL=http://localhost:8080

# JPA and Hibernate settings
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true
SPRING_JPA_FORMAT_SQL=true
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQLDialect
SPRING_JPA_HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# Connection pool
SPRING_DATASOURCE_HIKARI_CONNECTION_TIMEOUT=30000
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=10
SPRING_DATASOURCE_HIKARI_IDLE_TIMEOUT=600000
SPRING_DATASOURCE_HIKARI_MAX_LIFETIME=1800000
